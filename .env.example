# 솔라피 API 환경 변수 가이드 (.env.example)
# 이 파일의 내용을 복사하여 Vercel의 Environment Variables 설정에 넣어주세요.

# 솔라피 API 키 정보 (솔라피 관리자 > API 키 관리에서 확인)
VITE_SOLAPI_API_KEY=YOUR_API_KEY_HERE
VITE_SOLAPI_API_SECRET=YOUR_API_SECRET_HERE

# 카카오톡 채널 정보
VITE_SOLAPI_PFID=YOUR_PFID_HERE
VITE_SOLAPI_TEMPLATE_ID=YOUR_TEMPLATE_ID_HERE

# 발신 번호 (솔라피에 등록된 번호)
VITE_SOLAPI_SENDER_NUMBER=01012345678
